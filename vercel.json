{
  "buildCommand": "",
  "functions": {
    "api/cron/summary.ts": {
      "maxDuration": 60
    },
    "api/cron/weekly-summary.ts": {
      "maxDuration": 120
    },
    "api/slack/events.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/summary",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/weekly-summary",
      "schedule": "0 0 * * 2"
    }
  ]
}
